{
  "name": "nocturne-timeline-museum",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "An interactive constellation timeline of art history with walkable 3D artist galleries. Fully static, data sourced from Wikipedia / Wikidata / Wikimedia Commons.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "fetch-data": "node scripts/fetchWikiData.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
